# Copy to .env.local as needed
REPOSITORY_DRIVER=sql
DEFAULT_CURRENCY=KES
SAP_EXPORT_VERSION_DEFAULT=V1

# App runtime (least privilege) — after applying docs/migrations/005-app-budget-ops-role.sql
# Requires SQL Server mixed-mode auth. Change the password in production.
SQLSERVER_CONNECTION_STRING=Server=localhost\SQLEXPRESS;Database=BudgetOperations;User Id=app_budget_ops;Password=CHANGE_ME;TrustServerCertificate=True;

# Admin / seed scripts may still use Windows auth:
# SQLSERVER_CONNECTION_STRING=Server=localhost\SQLEXPRESS;Database=BudgetOperations;Trusted_Connection=True;TrustServerCertificate=True;

# Auth
# HMAC secret for signed session cookies (min 32 chars). Required in production.
# SESSION_SECRET=replace-with-a-long-random-string-at-least-32-chars
# Base URL used in verification / password-reset email links
APP_BASE_URL=http://localhost:3000
# When set, emails are sent via SMTP; unset = dev mode (links logged/returned)
# SMTP_HOST=
# Initial password applied by `npm run db:passwords` to seeded users
# SEED_USER_PASSWORD=KenGen@2026

# Development Toolkit — BOTH required (never enable in staging/production):
# NODE_ENV=development (set automatically by `next dev`)
# ENABLE_DEVELOPMENT_TOOLKIT=true
ENABLE_DEVELOPMENT_TOOLKIT=false
