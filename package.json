{
  "name": "budget-operations",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:boundaries": "tsx scripts/architecture-guard/cli.ts",
    "lint:deps": "depcruise src --config .dependency-cruiser.cjs",
    "lint:browser": "tsx scripts/browser-safety-check.ts",
    "lint:architecture": "npm run lint:boundaries && npm run lint:deps",
    "verify:browser": "npm run build && npm run lint:browser",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:seed": "tsx scripts/seed-sql.ts",
    "db:reseed": "tsx scripts/seed-sql.ts",
    "db:migrate": "tsx scripts/migrate-all.ts",
    "db:passwords": "tsx scripts/set-passwords.ts",
    "e2e:spine": "tsx scripts/e2e-notification-spine.ts",
    "docs:check": "tsx scripts/docs-guard/cli.ts",
    "postinstall": "node scripts/patch-next-tsconfig-path.js"
  },
  "dependencies": {
    "client-only": "^0.0.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.469.0",
    "msnodesqlv8": "^5.2.1",
    "mssql": "^12.7.0",
    "next": "14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "server-only": "^0.0.1",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/mssql": "^12.3.0",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.20",
    "dependency-cruiser": "^18.1.0",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.23.1",
    "typescript": "5.4.5",
    "vitest": "^2.1.8"
  }
}
